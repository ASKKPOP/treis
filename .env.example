# Treis — shared environment config for all subprojects
# Copy to .env and fill in your values

# ── Model provider ────────────────────────────────────────────
# "anthropic" or "ollama" (default: ollama)
TREIS_MODEL_PROVIDER=ollama

# Model ID to use
# Ollama examples:  llama3.2  mistral  phi3
# Anthropic examples: claude-haiku-4-5-20251001  claude-sonnet-4-6
TREIS_MODEL_ID=llama3.2

# ── Anthropic (required when TREIS_MODEL_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=

# ── Ollama (optional overrides) ───────────────────────────────
# Default endpoint is http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
